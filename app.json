{
  "expo": {
    "name": "TDT-KIOSK",
    "slug": "TDT-KIOSK",
    "version": "1.0.1",
    "orientation": "default",
    "icon": "./assets/tdt-logo-new.png",
    "userInterfaceStyle": "light",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "This app needs access to your camera for face recognition."
      },
      "bundleIdentifier": "com.ams.attendanceapp"
    },
    "android": {
      "package": "com.ams.attendanceapp",
      "versionCode": 1,
      "predictiveBackGestureEnabled": false,
      "adaptiveIcon": {
        "foregroundImage": "./assets/tdt-logo-new.png",
        "backgroundColor": "#ffffff"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "plugins": [
      "expo-dev-client",
      [
        "expo-build-properties",
        {
          "android": {
            "minSdkVersion": 26
          }
        }
      ],
      [
        "react-native-vision-camera",
        {
          "cameraPermissionText": "This app needs access to your camera for face recognition.",
          "enableCodeScanner": true
        }
      ],
      "expo-asset",
      "./plugins/withOnnxManualLink.js",
      "expo-sharing",
      "expo-status-bar",
      "expo-splash-screen"
    ],
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "tdtqrscanner",
    "extra": {
      "eas": {
        "projectId": "3431bf76-27da-49aa-8940-e0e6952af2a3"
      }
    }
  }
}
