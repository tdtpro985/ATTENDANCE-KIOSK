+    jsi::Object object = arg.asObject(runtime);
+#ifdef NITRO_DEBUG
+    if (!object.hasNativeState(runtime)) [[unlikely]] {
+      std::string stringRepresentation = arg.toString(runtime).utf8(runtime);
