{
  "name": "myapp",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start",
    "dev": "node scripts/dev.js",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "build:android": "eas build --platform android --profile preview",
    "test": "jest",
    "postinstall": "patch-package && node ./scripts/patch-onnx.js"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/cli": "latest",
    "@react-native-community/netinfo": "12.0.1",
    "expo": "^56.0.12",
    "expo-asset": "~56.0.17",
    "expo-av": "^16.0.8",
    "expo-build-properties": "~56.0.19",
    "expo-camera": "~56.0.8",
    "expo-dev-client": "~56.0.20",
    "expo-file-system": "~56.0.8",
    "expo-image-manipulator": "~56.0.19",
    "expo-location": "~56.0.18",
    "expo-screen-orientation": "~56.0.5",
    "expo-sharing": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "jpeg-js": "^0.4.4",
    "onnxruntime-react-native": "^1.24.3",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-maps": "1.27.2",
    "react-native-mmkv": "^4.3.1",
    "react-native-nitro-modules": "^0.35.9",
    "react-native-reanimated": "4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-vision-camera": "^4.6.4",
    "react-native-vision-camera-face-detector": "^2.0.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "^0.8.0",
    "react-native-worklets-core": "^1.6.3"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.14",
    "babel-preset-expo": "~56.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~56.0.5",
    "patch-package": "^8.0.1",
    "react-test-renderer": "^19.2.3",
    "typescript": "~6.0.3"
  },
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "transformIgnorePatterns": [
      "node_modules/(?!((jest-)?react-native|@react-native(-community)?)|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg)"
    ]
  },
  "private": true,
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "expo-av",
          "onnxruntime-react-native",
          "react-native-vision-camera-face-detector",
          "expo-modules-jsi"
        ],
        "listUnknownPackages": false
      }
    }
  }
}
